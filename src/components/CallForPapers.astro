---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="cfp" class="cfp">
  <div class="container">
    <div class="cfp-card animate-fade-in">
      <div class="cfp-content">
        <h2 class="title">{t('cfp.title')}</h2>
        <div class="status-badge">{t('cfp.status')}</div>
        <div class="deadline">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <span>{t('cfp.deadline')}</span>
        </div>
      </div>
      <div class="cfp-action">
        <button class="btn btn-primary btn-register-trigger">{lang === 'es' ? 'Enviar Propuesta' : 'Submit Proposal'}</button>
      </div>
    </div>
  </div>
</section>

<style>
  .cfp {
    background-color: var(--bg-alt);
    padding: 120px 20px;
  }

  .cfp-card {
    background: var(--primary-dark); /* Use Dark Blue for the card */
    color: var(--secondary);
    padding: 80px;
    border-radius: 4px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.3);
    border-left: 8px solid var(--accent-dark); /* Add Dark Gold border */
  }

  .cfp-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(242, 151, 39, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .title {
    font-size: 2.5rem;
    margin-bottom: 20px;
    font-weight: 800;
  }

  .status-badge {
    display: inline-block;
    background: var(--accent);
    color: var(--primary-dark);
    padding: 10px 24px;
    font-weight: 900;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 30px;
    border-radius: 2px;
  }

  .deadline {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 1.25rem;
    font-weight: 600;
    opacity: 0.95;
    color: var(--bg-light);
  }

  .deadline svg {
    color: var(--accent);
  }

  .btn-primary {
    padding: 20px 40px;
    font-size: 1rem;
    background: var(--accent);
    color: var(--primary-dark);
    border: none;
    font-weight: 800;
  }

  .btn-primary:hover {
    background: var(--secondary);
    color: var(--primary-dark);
    transform: scale(1.05);
  }

  @media (max-width: 992px) {
    .cfp-card {
      flex-direction: column;
      text-align: center;
      padding: 60px 40px;
      gap: 40px;
    }
    .title {
      font-size: 2rem;
    }
    .deadline {
      justify-content: center;
    }
  }
</style>
