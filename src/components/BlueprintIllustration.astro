---
// Generate a massive, perfectly uniform and extremely dense architectural grid
const columns = 10;
const rows = 6;
const spacing = 400;

// Shift start coordinates to comfortably cover the viewBox: -960 to 2880 (X) and -540 to 1620 (Y)
const startX = -1000;
const startY = -600;

// Deterministic block assignment for coherence
function getBlockType(c: number, r: number) {
  const seed = Math.abs(c * 13 + r * 7);
  const modulo = seed % 10;
  if (modulo < 3) return 'officeWing';
  if (modulo < 5) return 'serverWing';
  if (modulo < 7) return 'conferenceWing';
  if (modulo < 9) return 'atriumWing';
  return 'labWing';
}

const blocks = [];
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < columns; c++) {
    const x = startX + c * spacing;
    const y = startY + r * spacing;
    // Add a slight rotation for variety in some blocks
    const rotate = (c + r) % 2 === 0 ? 0 : 90;
    blocks.push({ x, y, type: getBlockType(c, r), rotate });
  }
}

// Generate continuous structural columns across intersections
const pillars = [];
for (let r = 0; r <= rows; r++) {
  for (let c = 0; c <= columns; c++) {
    pillars.push({ x: startX + c * spacing, y: startY + r * spacing });
  }
}
---

<svg
  class="blueprint-svg"
  width="100%"
  height="100%"
  viewBox="-960 -540 3840 2160"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <!-- LIGHT GRAY PALETTE: #888, #999, #aaa. strictly NO white/solid backgrounds -->
    
    <!-- Base Grids -->
    <pattern id="smallGrid" width="20" height="20" patternUnits="userSpaceOnUse">
      <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#999" stroke-width="0.3" opacity="0.3" />
    </pattern>
    <pattern id="largeGrid" width="100" height="100" patternUnits="userSpaceOnUse">
      <rect width="100" height="100" fill="url(#smallGrid)" stroke="none" />
      <path d="M 100 0 L 0 0 0 100" fill="none" stroke="#888" stroke-width="0.5" opacity="0.4" />
    </pattern>

    <!-- Essential Textures (All Lines) -->
    <pattern id="hatch" width="8" height="8" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="0" y2="8" stroke="#888" stroke-width="0.8" opacity="0.6" />
    </pattern>
    <pattern id="crosshatch" width="10" height="10" patternTransform="rotate(0)" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="10" y2="10" stroke="#888" stroke-width="0.5" opacity="0.6"/>
      <line x1="10" y1="0" x2="0" y2="10" stroke="#888" stroke-width="0.5" opacity="0.6"/>
    </pattern>

    <!-- Architectural Elements -->
    <pattern id="deskGrid" width="80" height="80" patternUnits="userSpaceOnUse">
      <!-- 4 desks clustered together -->
      <rect x="10" y="10" width="25" height="15" fill="none" stroke="#888" stroke-width="1.5"/>
      <circle cx="22.5" cy="32" r="4" fill="none" stroke="#888" stroke-width="1"/>
      
      <rect x="45" y="10" width="25" height="15" fill="none" stroke="#888" stroke-width="1.5"/>
      <circle cx="57.5" cy="32" r="4" fill="none" stroke="#888" stroke-width="1"/>
      
      <rect x="10" y="55" width="25" height="15" fill="none" stroke="#888" stroke-width="1.5"/>
      <circle cx="22.5" cy="48" r="4" fill="none" stroke="#888" stroke-width="1"/>
      
      <rect x="45" y="55" width="25" height="15" fill="none" stroke="#888" stroke-width="1.5"/>
      <circle cx="57.5" cy="48" r="4" fill="none" stroke="#888" stroke-width="1"/>
    </pattern>

    <pattern id="techRacks" width="40" height="100" patternUnits="userSpaceOnUse">
      <!-- Racks, no fill -->
      <rect x="5" y="5" width="30" height="90" fill="none" stroke="#888" stroke-width="1.5"/>
      <line x1="5" y1="20" x2="35" y2="20" stroke="#888" stroke-width="1"/>
      <line x1="5" y1="35" x2="35" y2="35" stroke="#888" stroke-width="1"/>
      <line x1="5" y1="50" x2="35" y2="50" stroke="#888" stroke-width="1"/>
      <line x1="5" y1="65" x2="35" y2="65" stroke="#888" stroke-width="1"/>
      <line x1="5" y1="80" x2="35" y2="80" stroke="#888" stroke-width="1"/>
      <circle cx="20" cy="12" r="2" fill="none" stroke="#888" />
    </pattern>

    <pattern id="topoLines" width="200" height="200" patternUnits="userSpaceOnUse">
      <path d="M 0 50 Q 50 20 100 80 T 200 60" fill="none" stroke="#888" stroke-width="1" stroke-dasharray="8,4" />
      <path d="M 0 100 Q 80 80 120 150 T 200 120" fill="none" stroke="#888" stroke-width="1" />
      <path d="M 0 150 Q 60 180 150 100 T 200 180" fill="none" stroke="#888" stroke-width="1" stroke-dasharray="4,6" />
    </pattern>

    <pattern id="trees" width="100" height="100" patternUnits="userSpaceOnUse">
      <!-- Pure lines, circles representing foliage -->
      <circle cx="50" cy="50" r="40" fill="none" stroke="#888" stroke-width="1.5" stroke-dasharray="5,3" />
      <circle cx="50" cy="50" r="25" fill="none" stroke="#888" stroke-width="1" />
      <circle cx="50" cy="50" r="5" fill="none" stroke="#888" stroke-width="1.5" />
      <line x1="50" y1="10" x2="50" y2="25" stroke="#888" stroke-width="1" />
      <line x1="50" y1="75" x2="50" y2="90" stroke="#888" stroke-width="1" />
      <line x1="10" y1="50" x2="25" y2="50" stroke="#888" stroke-width="1" />
      <line x1="75" y1="50" x2="90" y2="50" stroke="#888" stroke-width="1" />
    </pattern>
    
    <pattern id="floorTiles" width="50" height="50" patternUnits="userSpaceOnUse">
      <rect width="50" height="50" fill="none" stroke="#888" stroke-width="1" />
      <line x1="25" y1="0" x2="25" y2="50" stroke="#888" stroke-width="0.5" stroke-dasharray="2,2" />
      <line x1="0" y1="25" x2="50" y2="25" stroke="#888" stroke-width="0.5" stroke-dasharray="2,2" />
    </pattern>

    <!-- ARCHITECTURAL MODULES (400x400 base size) -->
    <!-- 1. Office Wing -->
    <g id="officeWing" stroke="#888" fill="none">
      <!-- Walls -->
      <rect x="10" y="10" width="380" height="380" stroke-width="2" />
      <rect x="20" y="20" width="360" height="360" stroke-width="1" />
      <!-- Central Corridor -->
      <line x1="20" y1="200" x2="380" y2="200" stroke-width="1" stroke-dasharray="10,10" />
      <line x1="20" y1="160" x2="380" y2="160" stroke-width="1.5" />
      <line x1="20" y1="240" x2="380" y2="240" stroke-width="1.5" />
      <!-- Cubicles inside rooms -->
      <rect x="30" y="30" width="340" height="120" fill="url(#deskGrid)" stroke="none" />
      <rect x="30" y="250" width="340" height="120" fill="url(#deskGrid)" stroke="none" />
      <!-- Doors (Arcs) -->
      <path d="M 180 160 A 30 30 0 0 1 150 130" stroke-dasharray="3,3" />
      <line x1="180" y1="160" x2="150" y2="160" />
      <path d="M 220 240 A 30 30 0 0 1 250 270" stroke-dasharray="3,3" />
      <line x1="220" y1="240" x2="250" y2="240" />
    </g>

    <!-- 2. Server Wing -->
    <g id="serverWing" stroke="#888" fill="none">
      <!-- Reinforced Walls -->
      <rect x="10" y="10" width="380" height="380" stroke-width="3" />
      <!-- Internal layout -->
      <rect x="30" y="30" width="340" height="340" fill="url(#floorTiles)" stroke="none" />
      <!-- Server Racks arrays -->
      <rect x="50" y="50" width="120" height="300" fill="url(#techRacks)" stroke="none" />
      <rect x="230" y="50" width="120" height="300" fill="url(#techRacks)" stroke="none" />
      
      <!-- HVAC routing lines overhead -->
      <line x1="10" y1="100" x2="390" y2="100" stroke-width="2" stroke-dasharray="15,5,5,5" />
      <line x1="10" y1="300" x2="390" y2="300" stroke-width="2" stroke-dasharray="15,5,5,5" />
      <circle cx="200" cy="200" r="30" stroke-width="2" fill="url(#crosshatch)" />
      <!-- Structural X -->
      <line x1="10" y1="10" x2="390" y2="390" stroke-width="0.5" stroke-dasharray="5,5" />
      <line x1="390" y1="10" x2="10" y2="390" stroke-width="0.5" stroke-dasharray="5,5" />
    </g>

    <!-- 3. Conference Wing -->
    <g id="conferenceWing" stroke="#888" fill="none">
      <!-- Square bounds -->
      <rect x="10" y="10" width="380" height="380" stroke-width="2" />
      <!-- Massive circular auditorium -->
      <circle cx="200" cy="200" r="180" stroke-width="2" />
      <circle cx="200" cy="200" r="150" stroke-width="1.5" stroke-dasharray="20,10" />
      <circle cx="200" cy="200" r="120" stroke-width="1" stroke-dasharray="15,5" />
      <circle cx="200" cy="200" r="90" stroke-width="0.8" stroke-dasharray="10,5" />
      <!-- Stage -->
      <path d="M 120 200 A 80 80 0 0 0 280 200 Z" stroke-width="2" />
      <circle cx="200" cy="260" r="10" />
      <!-- Exits -->
      <line x1="20" y1="200" x2="60" y2="200" stroke-width="4" />
      <line x1="340" y1="200" x2="380" y2="200" stroke-width="4" />
      <!-- Presentation text representation -->
      <rect x="150" y="150" width="100" height="20" stroke-width="1" />
    </g>

    <!-- 4. Atrium / Landscaping Wing -->
    <g id="atriumWing" stroke="#888" fill="none">
      <rect x="10" y="10" width="380" height="380" stroke-width="1" stroke-dasharray="5,5" />
      <!-- Topo and trees mix -->
      <rect x="10" y="10" width="380" height="380" fill="url(#topoLines)" stroke="none" />
      <circle cx="100" cy="100" r="80" fill="url(#trees)" stroke="none" />
      <circle cx="300" cy="300" r="90" fill="url(#trees)" stroke="none" />
      <circle cx="320" cy="120" r="60" fill="url(#trees)" stroke="none" />
      <!-- Pedestrian paths cutting through -->
      <path d="M 10 200 Q 200 100 390 300" stroke-width="3" stroke-dasharray="10,5" />
      <path d="M 200 10 Q 150 200 250 390" stroke-width="3" stroke-dasharray="10,5" />
      <!-- Center node -->
      <circle cx="200" cy="200" r="40" stroke-width="2" fill="url(#smallGrid)" />
      <circle cx="200" cy="200" r="20" stroke-width="1" />
    </g>

    <!-- 5. Lab Wing / Workshop -->
    <g id="labWing" stroke="#888" fill="none">
      <rect x="10" y="10" width="380" height="380" stroke-width="2" />
      <!-- Complex nested rooms -->
      <rect x="20" y="20" width="160" height="160" stroke-width="1.5" />
      <rect x="220" y="20" width="160" height="160" stroke-width="1.5" />
      <rect x="20" y="220" width="160" height="160" stroke-width="1.5" />
      <rect x="220" y="220" width="160" height="160" stroke-width="1.5" />
      
      <!-- Inner lab benches -->
      <rect x="40" y="40" width="120" height="40" fill="url(#hatch)" stroke="none" />
      <rect x="240" y="40" width="120" height="40" fill="url(#hatch)" stroke="none" />
      <rect x="40" y="240" width="120" height="40" fill="url(#hatch)" stroke="none" />
      <rect x="240" y="240" width="120" height="40" fill="url(#hatch)" stroke="none" />
      
      <!-- Central core -->
      <circle cx="200" cy="200" r="40" stroke-width="2" />
      <rect x="190" y="190" width="20" height="20" />
      
      <!-- Connecting tubes -->
      <line x1="180" y1="100" x2="220" y2="100" stroke-width="1" />
      <line x1="180" y1="300" x2="220" y2="300" stroke-width="1" />
      <line x1="100" y1="180" x2="100" y2="220" stroke-width="1" />
      <line x1="300" y1="180" x2="300" y2="220" stroke-width="1" />
    </g>

  </defs>

  <!-- Massive Background Grid covering entire canvas -->
  <rect x="-1000" y="-1000" width="6000" height="4000" fill="url(#largeGrid)" opacity="0.6" />

  <!-- The Architectural Blueprint Composition -->
  <g stroke-linecap="round" stroke-linejoin="round">
    
    <!-- Generate the massive 10x6 block plan -->
    {blocks.map(block => (
      <g transform={`translate(${block.x}, ${block.y}) rotate(${block.rotate}, 200, 200)`}>
        <use href={`#${block.type}`} />
        <!-- Subtle block coordinate ID for architectural feel -->
        <text 
          x="10" 
          y="15" 
          font-family="monospace" 
          font-size="12" 
          fill="#888" 
          stroke="none" 
          opacity="0.5"
        >
          SEC {Math.abs(block.x) / 10}-{Math.abs(block.y) / 10}
        </text>
      </g>
    ))}

    <!-- Global Structure Connectors: Long intersecting lines mimicking primary structural framing -->
    <g stroke="#888" fill="none" opacity="0.8">
      <!-- Horizontal master beams -->
      {Array.from({length: rows + 1}).map((_, i) => (
        <g>
          <line x1={startX} y1={startY + i * spacing} x2={startX + columns * spacing} y2={startY + i * spacing} stroke-width="3" />
          <line x1={startX} y1={startY + i * spacing + 10} x2={startX + columns * spacing} y2={startY + i * spacing + 10} stroke-width="0.5" stroke-dasharray="10,5" />
        </g>
      ))}
      
      <!-- Vertical master beams -->
      {Array.from({length: columns + 1}).map((_, i) => (
        <g>
          <line x1={startX + i * spacing} y1={startY} x2={startX + i * spacing} y2={startY + rows * spacing} stroke-width="3" />
          <line x1={startX + i * spacing + 10} y1={startY} x2={startX + i * spacing + 10} y2={startY + rows * spacing} stroke-width="0.5" stroke-dasharray="10,5" />
        </g>
      ))}

      <!-- Intersection Pillars -->
      {pillars.map(pillar => (
        <g transform={`translate(${pillar.x}, ${pillar.y})`}>
          <rect x="-15" y="-15" width="30" height="30" stroke-width="2" />
          <circle cx="0" cy="0" r="10" stroke-width="1.5" />
        </g>
      ))}

      <!-- Giant global diagonals representing main structural bracing -->
      <line x1={startX} y1={startY} x2={startX + columns * spacing} y2={startY + rows * spacing} stroke-width="1" stroke-dasharray="30,15" opacity="0.3" />
      <line x1={startX + columns * spacing} y1={startY} x2={startX} y2={startY + rows * spacing} stroke-width="1" stroke-dasharray="30,15" opacity="0.3" />
    </g>

    <!-- Center Crosshairs / Core Alignment framing (aligned exactly to 1920x1080 center, which is now at 960x540) -->
    <g stroke="#888" stroke-width="1" fill="none" opacity="0.7">
      <!-- The center point in the new coordinates is exactly X=960, Y=540 -->
      <circle cx="960" cy="540" r="800" stroke-dasharray="20,10" stroke-width="2" />
      <circle cx="960" cy="540" r="820" stroke-width="0.5" />
      
      <!-- Crosshairs traversing the whole screen -->
      <line x1="-960" y1="540" x2="2880" y2="540" stroke-width="1.5" stroke-dasharray="40,10,10,10" />
      <line x1="960" y1="-540" x2="960" y2="1620" stroke-width="1.5" stroke-dasharray="40,10,10,10" />

      <!-- Core Box -->
      <rect x="560" y="340" width="800" height="400" stroke-width="1" stroke-dasharray="5,5" />
      
      <!-- Text details near center -->
      <text x="960" y="520" font-family="monospace" font-size="16" fill="#888" stroke="none" text-anchor="middle" font-weight="bold" opacity="0.6">
        CILUC 2026 - MASTER PLAN OVERVIEW
      </text>
      <text x="960" y="565" font-family="monospace" font-size="12" fill="#888" stroke="none" text-anchor="middle" letter-spacing="4" opacity="0.5">
        SCALE 1:5000 | COORD 960,540
      </text>
    </g>

  </g>
</svg>

<style>
  .blueprint-svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
</style>
