<script>
  // Wait for the DOM to be ready
  document.addEventListener('DOMContentLoaded', () => {
    const svg = document.querySelector('.city-svg');
    if (!svg) return;

    // Simple deterministic hash so the widths are stable between page loads
    // but vary per element (no true random jitter on every load)
    function pseudoRandom(seed: number) {
      let s = seed;
      s = ((s >> 16) ^ s) * 0x45d9f3b;
      s = ((s >> 16) ^ s) * 0x45d9f3b;
      s = (s >> 16) ^ s;
      // Normalize to [0, 1]
      return (s & 0xffff) / 0xffff;
    }

    const elements = svg.querySelectorAll('line, rect, path');
    elements.forEach((el, index) => {
      const base = parseFloat(el.getAttribute('stroke-width') || '0.5');
      // Hash based on index + x1/y1 attributes for stable variation
      const x1 = parseInt(el.getAttribute('x1') || el.getAttribute('x') || '0', 10);
      const y1 = parseInt(el.getAttribute('y1') || el.getAttribute('y') || '0', 10);
      const seed = (index * 2654435761 + x1 * 40503 + y1 * 12345) | 0;
      const factor = 1.0 + pseudoRandom(seed); // range [1.0, 2.0]
      el.setAttribute('stroke-width', (base * factor).toFixed(3));
    });
  });
</script>
