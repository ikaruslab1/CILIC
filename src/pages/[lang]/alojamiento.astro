---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Hero from "../../components/Hero.astro";
import Footer from "../../components/Footer.astro";
import AccommodationCards from "../../components/AccommodationCards.tsx";
import { ui } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);

// Text translations to pass to the React component
const labels = {
  viewDetails: t("accommodation.viewDetails") || "Ver detalles"
};
---

<BaseLayout
  title={`${t("nav.accommodation")} | CILUC 2026`}
  description={t("accommodation.description")}
>
  <Navbar />
  <main>
    <Hero title={t("nav.accommodation")} hideCountdown={true} isCompact={true} />
    
    <AccommodationCards client:load labels={labels} lang={lang as string} />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  body {
    background-color: #f0f2f5;
  }
</style>
